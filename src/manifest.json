{
  "manifest_version": 3,
  "name": "Next New Tab",
  "version": "0.1.0",
  "description": "Beautiful new tab with wallpapers, bookmarks and search",
  "permissions": ["storage", "bookmarks"],
  "chrome_url_overrides": {
    "newtab": "src/newtab/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  }
}
